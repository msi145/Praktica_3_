<UserControl x:Class="WmsClient.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Остатки готовой продукции" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="Обновить из БД" Width="150" Height="32" Margin="20,0,0,0" Click="BtnRefresh_Click"/>
            <Button x:Name="BtnSend" Content="Отправить в 1С" Width="150" Height="32" Margin="10,0,0,0"
                    Background="#4CAF50" Foreground="White" FontWeight="Bold" Click="BtnSend_Click"/>
        </StackPanel>

        <DataGrid x:Name="Grid" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"
                  GridLinesVisibility="Horizontal" AlternatingRowBackground="#F7F9FB"/>

        <TextBlock x:Name="StatusText" Grid.Row="2" Margin="0,10,0,0" TextWrapping="Wrap" Foreground="#555"/>
    </Grid>
</UserControl>
